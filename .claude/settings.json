{
  "extraKnownMarketplaces": {
    "superpowers-repo": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "ponytail-repo": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@superpowers-repo": true,
    "ponytail@ponytail-repo": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
